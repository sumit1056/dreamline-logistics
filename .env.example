GEMINI_API_KEY=YOUR_FREE_GEMINI_API_KEY_HERE
PORT=3000

# WhatsApp Filter Configuration
# 1. TRACKED_GROUP_NAME: (Optional) Set to a specific WhatsApp group name to ONLY log messages sent in this group.
# Leave blank to listen to all group chats the bot is a member of.
# Example: TRACKED_GROUP_NAME=Dreamline Logistics Logs
TRACKED_GROUP_NAME=

# 2. ALLOW_DMS: (Optional) Set to "true" to allow logging via direct 1-to-1 messages to the bot (perfect for private entries).
# Set to "false" to disable direct message logging entirely. Defaults to true.
ALLOW_DMS=true
